{
  "includeCoAuthoredBy": false,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash(*git commit*)",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/validate-commit.sh"
          }
        ]
      }
    ]
  },
  "effortLevel": "medium",
  "autoDreamEnabled": false,
  "skipDangerousModePermissionPrompt": true,
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true
  }
}
